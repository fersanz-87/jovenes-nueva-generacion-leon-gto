# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Email service (si se usa)
EMAIL_SERVICE_API_KEY=
EMAIL_TO=jn_generacion@hotmail.com

# Cloudinary (entrega: CldImage, metadatos OG, etc.)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name_aqui

# Cloudinary (subidas firmadas desde el servidor — no subas secretos al repo)
CLOUDINARY_API_KEY=tu_api_key_aqui
CLOUDINARY_API_SECRET=tu_api_secret_aqui
# Nombre del upload preset en modo "Signed" (Settings → Upload → Upload presets)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=nombre_preset_firmado
